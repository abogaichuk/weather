WEATHER_DIR=./data

# Required. Semicolon-separated list of accepted bearer tokens — one per user.
# Each request must send `Authorization: Bearer <token>`. The server starts
# only if at least one non-empty token is present. Generate each token with
# e.g. `openssl rand -hex 32`. Whitespace around tokens is trimmed.
API_KEYS=token-for-user-a;token-for-user-b

# Bounding box of the region to ingest and serve (degrees, WGS84).
# The example covers central Europe — set it to your area of interest.
TOP_LAT=55.0
BOTTOM_LAT=47.0
LEFT_LON=5.0
RIGHT_LON=16.0

# Log level for `tracing`. Examples:
#   info                             all crates at INFO and above
#   weather_api=debug,info           DEBUG for the server, INFO for dependencies
#   weather_api=trace,tower_http=debug
RUST_LOG=info
